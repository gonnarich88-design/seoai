# =============================================================================
# Database & Queue (required)
# =============================================================================

DATABASE_URL=postgresql://postgres:dev@localhost:5432/seoai
REDIS_URL=redis://localhost:6379

# =============================================================================
# Auth (required — min 8 chars)
# =============================================================================

AUTH_PASSWORD=changeme-minimum-8-chars

# =============================================================================
# AI API Keys (at least one required)
# =============================================================================

OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AI...
PERPLEXITY_API_KEY=pplx-...

# =============================================================================
# Daily Budget Caps per platform (USD, default: $1.00/day each)
# =============================================================================

DAILY_BUDGET_OPENAI=1.0
DAILY_BUDGET_PERPLEXITY=1.0
DAILY_BUDGET_GEMINI=1.0

# =============================================================================
# Scheduler (cron syntax)
# =============================================================================

# Daily check schedule (default: midnight every day)
CHECK_SCHEDULE_CRON=0 0 * * *

# Weekly report schedule (default: Monday 9am)
WEEKLY_REPORT_CRON=0 9 * * 1

# =============================================================================
# Email / SMTP (optional — required for alerts and weekly reports)
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=SEO AI Monitor <noreply@yourdomain.com>

# Email address to receive alert notifications
ALERT_EMAIL_TO=team@yourdomain.com
